# Hyperliquid private key (hex, with or without 0x prefix)
HL_PRIVATE_KEY=

# API URL (default: mainnet). Overridden when HL_TESTNET=true.
HL_API_URL=https://api.hyperliquid.xyz

# Use Hyperliquid testnet (real orders but with test funds)
HL_TESTNET=false

# Dry-run mode: log orders instead of sending them (can also use --dry-run flag)
HL_DRY_RUN=false

# Safety: refuse to open positions without a stop-loss
HL_NO_STOP_NO_TRADE=false

# Default stop-loss percentage from entry price
HL_DEFAULT_SL_PCT=2.0

# Default slippage for market/trigger orders (0.05 = 5%)
HL_DEFAULT_SLIPPAGE=0.05

# Monitor polling interval in seconds
HL_MONITOR_INTERVAL_SECONDS=5

# Telegram alerts (optional — leave blank to disable)
HL_TELEGRAM_BOT_TOKEN=
HL_TELEGRAM_CHAT_ID=

# Scan watcher settings
HL_SCAN_INTERVAL_SECONDS=3600
HL_SCAN_COOLDOWN_SECONDS=3600
